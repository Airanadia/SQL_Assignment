 schema="main" name="Project" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="49"/><column index="2" value="187"/><column index="3" value="85"/><column index="4" value="85"/><column index="5" value="124"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">
CREATE TABLE Department(
    Num_S INTEGER PRIMARY KEY,
    Label TEXT,
    Manager_Name TEXT
);

CREATE TABLE Employee(
    Num_E INTEGER PRIMARY KEY,
    Name TEXT,
    Position TEXT,
    Salary REAL,
    Department_Num_S INTEGER,
    FOREIGN KEY (Department_Num_S) REFERENCES Department(Num_S)
);

CREATE TABLE Project(
    Num_P INTEGER PRIMARY KEY,
    Title TEXT,
    Start_Date DATE,
    End_Date DATE,
    Department_Num_S INTEGER,
    FOREIGN KEY (Department_Num_S) REFERENCES Department(Num_S)
);

CREATE TABLE Employee_Project(
    Employee_Num_E INTEGER,
    Project_Num_P INTEGER,
    Role TEXT,
    PRIMARY KEY (Employee_Num_E, Project_Num_P),
    FOREIGN KEY (Employee_Num_E) REFERENCES Employee(Num_E),
    FOREIGN KEY (Project_Num_P) REFERENCES Project(Num_P)
);

