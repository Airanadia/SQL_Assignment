<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Assignment_3.db" readonly="0" foreign_keys="0" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1659"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Employee_Project" custom_title="0" dock_id="1" table="4,16:mainEmployee_Project"/><dock_state state="000000ff00000000fd0000000100000002000002f2000002a6fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000002f20000011800ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Department" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="48"/><column index="2" value="78"/><column index="3" value="109"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Employee" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="48"/><column index="2" value="109"/><column index="3" value="117"/><column index="4" value="62"/><column index="5" value="124"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Employee_Project" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="111"/><column index="2" value="98"/><column index="3" value="163"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Project" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="49"/><column index="2" value="187"/><column index="3" value="85"/><column index="4" value="85"/><column index="5" value="124"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT
    E.Name,
    COUNT(EP.Project_Num_P) AS TotalProjects
FROM Employee E
JOIN Employee_project EP
ON E.Num_E = EP.Employee_Num_E
GROUP BY E.Num_E, E.Name
HAVING COUNT(EP.Project_Num_P) &gt; 1;

SELECT
    D.Num_S,
    COUNT(E.Num_E) AS TotalEmployees
FROM Department D
JOIN Employee E
ON D.Num_S = E.Department_Num_S
GROUP BY D.Num_S
ORDER BY TotalEmployees DESC
LIMIT 1;

SELECT
    D.Num_S,
    COUNT(E.Num_E) AS TotalEmployees
FROM Department D
JOIN Employee E
ON D.Num_S = E.Department_Num_S
GROUP BY D.Num_S
ORDER BY TotalEmployees DESC
LIMIT 1;

SELECT
    E.Name,
    E.Position,
    D.Num_S
FROM Employee E
JOIN Department D
ON E.Department_Num_S = D.Num_S
WHERE E.Salary &gt; 60000;

SELECT
    E.Name,
    P.Title,
    EP.Role
FROM Employee E
JOIN Employee_project EP
ON E.Num_E = EP.Employee_Num_E
JOIN Project P
ON EP.Project_Num_P = P.Num_P;

SELECT
    D.Num_S,
    SUM(E.Salary) AS TotalSalary
FROM Department D
JOIN Employee E
ON D.Num_S = E.Department_Num_S
GROUP BY D.Num_S;</sql><current_tab id="0"/></tab_sql></sqlb_project>
